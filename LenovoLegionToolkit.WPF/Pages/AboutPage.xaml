<wpfui:UiPage
    x:Class="LenovoLegionToolkit.WPF.Pages.AboutPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:resources="clr-namespace:LenovoLegionToolkit.WPF.Resources"
    xmlns:utils="clr-namespace:LenovoLegionToolkit.WPF.Utils"
    xmlns:wpfui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="{x:Static resources:Resource.AboutPage_Title}"
    FlowDirection="{x:Static utils:LocalizationHelper.Direction}"
    Scrollable="True">

    <StackPanel Margin="0,0,16,12">
        <TextBlock
            Margin="0,16,0,24"
            Focusable="True"
            FontSize="24"
            FontWeight="Medium"
            Text="{x:Static resources:Resource.AboutPage_Title}" />

        <TextBlock
            Padding="0,0,0,8"
            Focusable="True"
            FontSize="16"
            FontWeight="Medium"
            Text="{x:Static resources:Resource.AboutPage_AppName}" />
        <TextBlock
            x:Name="_version"
            Padding="0,0,0,8"
            Focusable="True"
            Text="{x:Static resources:Resource.AboutPage_Version}" />
        <TextBlock
            x:Name="_build"
            Padding="0,0,0,16"
            Focusable="True"
            Text="{x:Static resources:Resource.AboutPage_Build}" />

        <TextBlock x:Name="_copyright" Focusable="True" />
        <TextBlock
            x:Name="_translationCredit"
            Padding="0,8,0,0"
            Text="{x:Static resources:Resource.AboutPage_TranslationCredit}" />

        <TextBlock
            Padding="0,24,0,8"
            Focusable="True"
            FontSize="14"
            FontWeight="Medium"
            Text="{x:Static resources:Resource.AboutPage_Links}" />
        <wpfui:Hyperlink
            Click="Hyperlink_Click"
            Content="{x:Static resources:Resource.AboutPage_ProjectWebsiteOnGitHub}"
            Icon="Link24"
            Tag="https://github.com/LenovoLegionToolkit-Team/LenovoLegionToolkit" />
        <wpfui:Hyperlink
            Click="Hyperlink_Click"
            Content="{x:Static resources:Resource.AboutPage_LatestReleaseOnGitHub}"
            Icon="Link24"
            Tag="https://github.com/LenovoLegionToolkit-Team/LenovoLegionToolkit/releases/latest" />

        <TextBlock
            Padding="0,24,0,8"
            Focusable="True"
            FontSize="14"
            FontWeight="Medium"
            Text="{x:Static resources:Resource.AboutPage_ThirdPartyLibraries}" />

        <WrapPanel>
            <wpfui:Hyperlink Click="Hyperlink_Click" Content="AsyncLock" Tag="https://github.com/neosmart/AsyncLock" />
            <wpfui:Hyperlink Click="Hyperlink_Click" Content="Autofac" Tag="https://github.com/autofac/Autofac" />
            <wpfui:Hyperlink Click="Hyperlink_Click" Content="Ben.Demystifier" Tag="https://github.com/benaadams/Ben.Demystifier" />
            <wpfui:Hyperlink Click="Hyperlink_Click" Content="ColorPicker" Tag="https://github.com/PixiEditor/ColorPicker" />
            <wpfui:Hyperlink Click="Hyperlink_Click" Content="CoordinateSharp" Tag="https://github.com/Tronald/CoordinateSharp" />
            <wpfui:Hyperlink Click="Hyperlink_Click" Content="CsWin32" Tag="https://github.com/microsoft/CsWin32" />
            <wpfui:Hyperlink Click="Hyperlink_Click" Content="Humanizer" Tag="https://github.com/Humanizr/Humanizer" />
            <wpfui:Hyperlink Click="Hyperlink_Click" Content="LibreHardwareMonitor" Tag="https://github.com/LibreHardwareMonitor/LibreHardwareMonitor" />
            <wpfui:Hyperlink Click="Hyperlink_Click" Content="ManagedNativeWifi" Tag="https://github.com/emoacht/ManagedNativeWifi" />
            <wpfui:Hyperlink Click="Hyperlink_Click" Content="Markdig" Tag="https://github.com/xoofx/markdig" />
            <wpfui:Hyperlink Click="Hyperlink_Click" Content="Markdig.Wpf" Tag="https://github.com/Kryptos-FR/markdig.wpf" />
            <wpfui:Hyperlink Click="Hyperlink_Click" Content="NAudio.Wasapi" Tag="https://github.com/naudio/NAudio" />
            <wpfui:Hyperlink Click="Hyperlink_Click" Content="Newtonsoft.Json" Tag="https://github.com/JamesNK/Newtonsoft.Json" />
            <wpfui:Hyperlink Click="Hyperlink_Click" Content="NvAPIWrapper" Tag="https://github.com/tebjan/NvAPIWrapper" />
            <wpfui:Hyperlink Click="Hyperlink_Click" Content="NvAPIWrapper" Tag="https://github.com/falahati/NvAPIWrapper" />
            <wpfui:Hyperlink Click="Hyperlink_Click" Content="Octokit" Tag="https://github.com/octokit/octokit.net" />
            <wpfui:Hyperlink Click="Hyperlink_Click" Content="PawnIO" Tag="https://github.com/namazso/PawnIO" />
            <wpfui:Hyperlink Click="Hyperlink_Click" Content="PresentMonFps" Tag="https://github.com/lemutec/PresentMonFps" />
            <wpfui:Hyperlink Click="Hyperlink_Click" Content="PubSub" Tag="https://github.com/upta/pubsub" />
            <wpfui:Hyperlink Click="Hyperlink_Click" Content="RAMSPDToolkit" Tag="https://github.com/Blacktempel/RAMSPDToolkit" />
            <wpfui:Hyperlink Click="Hyperlink_Click" Content="TaskScheduler" Tag="https://github.com/dahall/TaskScheduler" />
            <wpfui:Hyperlink Click="Hyperlink_Click" Content="UniversalFanControl.Lib" Tag="https://www.nuget.org/packages/UniversalFanControl.Lib" />
            <wpfui:Hyperlink Click="Hyperlink_Click" Content="WindowsDisplayAPI" Tag="https://github.com/falahati/WindowsDisplayAPI" />
            <wpfui:Hyperlink Click="Hyperlink_Click" Content="WPF-UI" Tag="https://github.com/lepoco/wpfui" />
            <wpfui:Hyperlink Click="Hyperlink_Click" Content="WpfScreenHelper" Tag="https://github.com/micdenny/WpfScreenHelper" />
            <wpfui:Hyperlink Click="Hyperlink_Click" Content="ZenStates-Core" Tag="https://github.com/irusanov/ZenStates-Core" />
        </WrapPanel>

        <TextBlock
            Padding="0,24,0,8"
            AutomationProperties.Name="{Binding RelativeSource={RelativeSource Mode=Self}, Path=Text}"
            Focusable="True"
            FontSize="14"
            FontWeight="Medium"
            Text="{x:Static resources:Resource.AboutPage_ApplicationFolders}" />

        <wpfui:Hyperlink
            Click="OpenApplicationDataFolder_Click"
            Content="{x:Static resources:Resource.AboutPage_Data}"
            Icon="Folder24" />
        <wpfui:Hyperlink
            Click="OpenApplicationTempFolder_Click"
            Content="{x:Static resources:Resource.AboutPage_Temp}"
            Icon="Folder24" />
        <wpfui:Hyperlink
            Click="OpenLogFolder_Click"
            Content="{x:Static resources:Resource.AboutPage_Log}"
            Icon="Folder24" />

    </StackPanel>
</wpfui:UiPage>
