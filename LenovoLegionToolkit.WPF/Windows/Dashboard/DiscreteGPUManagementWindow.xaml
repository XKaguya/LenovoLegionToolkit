<local:BaseWindow
    x:Class="LenovoLegionToolkit.WPF.Windows.Dashboard.DiscreteGPUManagementWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:LenovoLegionToolkit.WPF.Windows"
    xmlns:custom="clr-namespace:LenovoLegionToolkit.WPF.Controls.Custom"
    xmlns:dashboard="clr-namespace:LenovoLegionToolkit.WPF.Windows.Dashboard"
    xmlns:resources="clr-namespace:LenovoLegionToolkit.WPF.Resources"
    xmlns:utils="clr-namespace:LenovoLegionToolkit.WPF.Utils"
    xmlns:wpfui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="{x:Static resources:Resource.DiscreteGPUControl_ManagementWindowTitle}"
    Width="650"
    Height="650"
    MinWidth="600"
    MinHeight="400"
    MaxWidth="800"
    MaxHeight="800"
    Background="{DynamicResource ApplicationBackgroundBrush}"
    ExtendsContentIntoTitleBar="True"
    FlowDirection="{x:Static utils:LocalizationHelper.Direction}"
    ResizeMode="CanResizeWithGrip"
    ShowInTaskbar="False"
    WindowStartupLocation="CenterOwner">

    <local:BaseWindow.Resources>
        <Style TargetType="TabControl">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0,16,0,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <Grid KeyboardNavigation.TabNavigation="Local">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,4" Panel.ZIndex="1" KeyboardNavigation.TabIndex="1" IsItemsHost="True" Background="Transparent" />
                            <ContentPresenter Grid.Row="1" ContentSource="SelectedContent" Margin="{TemplateBinding Padding}" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,24,0" />
            <Setter Property="Padding" Value="0,0,0,10" />
            <Setter Property="Width" Value="Auto" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border Background="{TemplateBinding Background}" BorderThickness="{TemplateBinding BorderThickness}" HorizontalAlignment="Stretch">
                            <StackPanel HorizontalAlignment="Stretch">
                                <ContentPresenter ContentSource="Header" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}" />
                                <Rectangle x:Name="ActiveIndicator" Height="3" Fill="Transparent" RadiusX="1.5" RadiusY="1.5" Margin="0" HorizontalAlignment="Stretch" />
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                                <Setter TargetName="ActiveIndicator" Property="Fill">
                                    <Setter.Value>
                                        <SolidColorBrush Color="{DynamicResource SystemAccentColorSecondary}" />
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="FontWeight" Value="Bold" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </local:BaseWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <wpfui:TitleBar
            Grid.Row="0"
            Title="{x:Static resources:Resource.DiscreteGPUControl_ManagementWindowTitle}"
            CanMaximize="False"
            ShowMaximize="False"
            ShowMinimize="False"
            UseSnapLayout="False" />

        <TabControl Grid.Row="1" Margin="16,0,16,16">
            <TabItem Header="{x:Static resources:Resource.DiscreteGPUControl_GraphicsPreferencesTabLabel}">

                <ListBox 
                    x:Name="_processListView" 
                    Background="Transparent" 
                    BorderThickness="0" 
                    Padding="0,0,12,0"
                    ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="Padding" Value="0,0,0,8" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <ContentPresenter />
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type dashboard:DiscreteGPUAppViewModel}">
                            <custom:CardControl Margin="0,0,0,8">
                                <custom:CardControl.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="{x:Static resources:Resource.DiscreteGPUControl_ForceKillProcessMenu}" CommandParameter="{Binding ProcessIds}" Click="KillProcessMenuItem_Click" IsEnabled="{Binding CanKill}">
                                            <MenuItem.Icon>
                                                <wpfui:SymbolIcon Symbol="Dismiss24" Foreground="{DynamicResource PaletteRedBrush}" />
                                            </MenuItem.Icon>
                                        </MenuItem>
                                    </ContextMenu>
                                </custom:CardControl.ContextMenu>
                                <custom:CardControl.Header>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Image Grid.Column="0" Source="{Binding Icon}" Width="32" Height="32" Margin="0,0,12,0" RenderOptions.BitmapScalingMode="HighQuality" />
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}" FontWeight="Medium" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{Binding Path}" FontSize="10" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="WrapWithOverflow" />
                                        </StackPanel>
                                    </Grid>
                                </custom:CardControl.Header>
                                <Grid VerticalAlignment="Center">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,16,0">
                                        <wpfui:SymbolIcon x:Name="_statusIcon" Symbol="Circle16" Filled="True" Foreground="{DynamicResource TextFillColorTertiaryBrush}" Margin="0,1,4,0" FontSize="12" />
                                        <TextBlock x:Name="_statusText" Text="{Binding Status}" FontWeight="Medium" Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                                    </StackPanel>
                                    <ComboBox 
                                        Grid.Column="1"
                                        Width="180"
                                        SelectedValue="{Binding Preference, Mode=TwoWay}" 
                                        SelectedValuePath="Tag"
                                        IsEnabled="{Binding IsPreferenceEnabled}"
                                        SelectionChanged="PreferenceComboBox_SelectionChanged">
                                        <ComboBoxItem Content="{x:Static resources:Resource.DiscreteGPUControl_PreferenceDefault}" Tag="Default" />
                                        <ComboBoxItem Content="{x:Static resources:Resource.DiscreteGPUControl_PreferenceIntegrated}" Tag="Integrated" />
                                        <ComboBoxItem Content="{x:Static resources:Resource.DiscreteGPUControl_PreferenceDiscrete}" Tag="Discrete" />
                                    </ComboBox>
                                </Grid>
                            </custom:CardControl>
                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding IsActive}" Value="True">
                                    <Setter TargetName="_statusIcon" Property="Foreground" Value="{DynamicResource SystemFillColorSuccessBrush}" />
                                    <Setter TargetName="_statusText" Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </TabItem>
            <TabItem Header="{x:Static resources:Resource.DiscreteGPUControl_MiscellaneousTabLabel}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="0,0,12,0">
                        <custom:CardControl Margin="0,0,0,8" Icon="Timer24">
                            <custom:CardControl.Header>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="{x:Static resources:Resource.DiscreteGPUControl_PollingIntervalTitle}" FontWeight="Medium" />
                                    <TextBlock Text="{x:Static resources:Resource.DiscreteGPUControl_PollingIntervalDescription}" FontSize="11" TextWrapping="WrapWithOverflow" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                </StackPanel>
                            </custom:CardControl.Header>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Slider 
                                    x:Name="_intervalSlider" 
                                    Width="140" 
                                    Minimum="1" 
                                    Maximum="10" 
                                    IsSnapToTickEnabled="True" 
                                    ValueChanged="IntervalSlider_ValueChanged" />
                                <TextBlock x:Name="_intervalText" Width="40" Margin="12,0,0,0" VerticalAlignment="Center" FontWeight="Medium" />
                            </StackPanel>
                        </custom:CardControl>

                        <custom:CardControl Margin="0,0,0,8" Icon="Play24">
                            <custom:CardControl.Header>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="{x:Static resources:Resource.DiscreteGPUControl_StartupDelayTitle}" FontWeight="Medium" />
                                    <TextBlock Text="{x:Static resources:Resource.DiscreteGPUControl_StartupDelayDescription}" FontSize="11" TextWrapping="WrapWithOverflow" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                </StackPanel>
                            </custom:CardControl.Header>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Slider 
                                    x:Name="_startupDelaySlider" 
                                    Width="140" 
                                    Minimum="0.5" 
                                    Maximum="5" 
                                    TickFrequency="0.5"
                                    IsSnapToTickEnabled="True" 
                                    ValueChanged="StartupDelaySlider_ValueChanged" />
                                <TextBlock x:Name="_startupDelayText" Width="40" Margin="12,0,0,0" VerticalAlignment="Center" FontWeight="Medium" />
                            </StackPanel>
                        </custom:CardControl>

                        <custom:CardControl Margin="0,0,0,8" Icon="Dismiss24">
                            <custom:CardControl.Header>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="{x:Static resources:Resource.DiscreteGPUControl_KillProcessDelayTitle}" FontWeight="Medium" />
                                    <TextBlock Text="{x:Static resources:Resource.DiscreteGPUControl_KillProcessDelayDescription}" FontSize="11" TextWrapping="WrapWithOverflow" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                </StackPanel>
                            </custom:CardControl.Header>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Slider 
                                    x:Name="_killDelaySlider" 
                                    Width="140" 
                                    Minimum="0.1" 
                                    Maximum="2" 
                                    TickFrequency="0.1"
                                    IsSnapToTickEnabled="True" 
                                    ValueChanged="KillDelaySlider_ValueChanged" />
                                <TextBlock x:Name="_killDelayText" Width="40" Margin="12,0,0,0" VerticalAlignment="Center" FontWeight="Medium" />
                            </StackPanel>
                        </custom:CardControl>
                        
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <Border Grid.Row="2" Background="{DynamicResource ControlFillColorDefaultBrush}" BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}" BorderThickness="0,1,0,0" Padding="16">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <wpfui:Button Content="{x:Static resources:Resource.Close}" Appearance="Primary" Width="100" Click="CloseButton_Click" />
            </StackPanel>
        </Border>
    </Grid>
</local:BaseWindow>
