<local:BaseWindow
    x:Class="LenovoLegionToolkit.WPF.Windows.Osd.OsdSettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="clr-namespace:LenovoLegionToolkit.WPF.Controls"
    xmlns:custom="clr-namespace:LenovoLegionToolkit.WPF.Controls.Custom"
    xmlns:local="clr-namespace:LenovoLegionToolkit.WPF.Windows"
    xmlns:resources="clr-namespace:LenovoLegionToolkit.WPF.Resources"
    xmlns:system="clr-namespace:System;assembly=System.Runtime"
    xmlns:utils="clr-namespace:LenovoLegionToolkit.WPF.Utils"
    xmlns:wpfui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="{Binding Source={x:Static resources:Resource.OsdWindow_Title}}"
    Width="460"
    Height="600"
    MinWidth="460"
    MinHeight="600"
    Background="Transparent"
    FlowDirection="{x:Static utils:LocalizationHelper.Direction}"
    ResizeMode="CanMinimize"
    ShowInTaskbar="False"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">

    <local:BaseWindow.Resources>
        <system:Double x:Key="PrimaryFontSize">14</system:Double>
        <system:Double x:Key="SecondaryFontSize">14</system:Double>
        <system:Double x:Key="TertiaryFontSize">12</system:Double>
        <system:Double x:Key="HeaderFontSize">18</system:Double>

        <Style BasedOn="{StaticResource {x:Type CheckBox}}" TargetType="CheckBox">
            <Setter Property="Margin" Value="0,6" />
            <Setter Property="FontSize" Value="{StaticResource PrimaryFontSize}" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
        </Style>

        <Style x:Key="HeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="{StaticResource HeaderFontSize}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
            <Setter Property="Margin" Value="0,0,0,15" />
        </Style>

        <Style BasedOn="{StaticResource {x:Type GroupBox}}" TargetType="GroupBox">
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="{DynamicResource CardStrokeColorDefaultSolidBrush}" />
            <Setter Property="Background" Value="{DynamicResource CardBackgroundFillColorDefaultBrush}" />
            <Setter Property="Margin" Value="0,0,0,16" />
            <Setter Property="Padding" Value="16,12" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GroupBox">
                        <Border BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                Background="{TemplateBinding Background}" 
                                CornerRadius="8" 
                                Padding="{TemplateBinding Padding}">
                            <StackPanel>
                                <TextBlock Text="{TemplateBinding Header}" 
                                           FontWeight="SemiBold" 
                                           FontSize="14" 
                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}" 
                                           Margin="0,0,0,12" />
                                <ContentPresenter />
                            </StackPanel>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="TabControl">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0,16,0,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <Grid KeyboardNavigation.TabNavigation="Local">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,4" Panel.ZIndex="1" KeyboardNavigation.TabIndex="1" IsItemsHost="True" Background="Transparent" />
                            <ContentPresenter Grid.Row="1" ContentSource="SelectedContent" Margin="{TemplateBinding Padding}" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,24,0" />
            <Setter Property="Padding" Value="0,0,0,10" />
            <Setter Property="Width" Value="Auto" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border Background="{TemplateBinding Background}" BorderThickness="{TemplateBinding BorderThickness}" HorizontalAlignment="Stretch">
                            <StackPanel HorizontalAlignment="Stretch">
                                <ContentPresenter ContentSource="Header" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}" />
                                <Rectangle x:Name="ActiveIndicator" Height="3" Fill="Transparent" RadiusX="1.5" RadiusY="1.5" Margin="0" HorizontalAlignment="Stretch" />
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                                <Setter TargetName="ActiveIndicator" Property="Fill" Value="{DynamicResource SystemAccentColorPrimaryBrush}" />
                                <Setter Property="FontWeight" Value="Bold" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </local:BaseWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <wpfui:TitleBar
            x:Name="_titleBar"
            Grid.Row="0"
            CanMaximize="false"
            ShowMaximize="false"
            ShowMinimize="false"
            UseSnapLayout="false" />

        <Grid
            Grid.Row="0"
            Height="24"
            Margin="12,8,12,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock
                Grid.Column="0"
                VerticalAlignment="Center"
                FontSize="12"
                IsHitTestVisible="False"
                Text="{Binding Source={x:Static resources:Resource.OsdWindow_Title}}" />

        </Grid>

        <Grid Grid.Row="1" Margin="16,0,16,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TabControl Grid.Row="0">
                <TabItem Header="{x:Static resources:Resource.OsdSettings_Tabs_General}">
                    <StackPanel>
                        <wpfui:CardControl Margin="0,0,0,8" Icon="Window24">
                            <wpfui:CardControl.Header>
                                <TextBlock Text="{x:Static resources:Resource.OsdSettings_General_OverlayStyle}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                            </wpfui:CardControl.Header>
                            <ComboBox
                                x:Name="_osdStyleComboBox"
                                Width="140"
                                SelectionChanged="StyleComboBox_SelectionChanged">
                                <ComboBoxItem Content="{x:Static resources:Resource.Osd_Style_Panel}" Tag="Panel" />
                                <ComboBoxItem Content="{x:Static resources:Resource.Osd_Style_Bar}" Tag="Bar" />
                            </ComboBox>
                        </wpfui:CardControl>

                        <wpfui:CardControl Margin="0,0,0,8" Icon="Timer24">
                            <wpfui:CardControl.Header>
                                <TextBlock Text="{x:Static resources:Resource.OsdSettings_General_RefreshInterval}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                            </wpfui:CardControl.Header>
                            <wpfui:NumberBox
                                x:Name="_osdRefreshInterval"
                                ToolTip="{x:Static resources:Resource.OsdSettings_General_RefreshInterval_Tooltip}"
                                Width="100"
                                Maximum="10"
                                Minimum="0.1"
                                SmallChange="0.1"
                                LargeChange="0.5"
                                MaxDecimalPlaces="1"
                                SpinButtonPlacementMode="Compact"
                                ValueChanged="OsdRefreshInterval_ValueChanged" />
                        </wpfui:CardControl>

                        <wpfui:CardControl Margin="0,0,0,8" Icon="Target24">
                            <wpfui:CardControl.Header>
                                <TextBlock Text="{x:Static resources:Resource.OsdSettings_General_SnapThreshold}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                            </wpfui:CardControl.Header>
                            <wpfui:NumberBox
                                x:Name="_osdSnapThreshold"
                                Width="100"
                                Maximum="100"
                                Minimum="0"
                                SpinButtonPlacementMode="Compact"
                                ValueChanged="OsdSnapThreshold_ValueChanged" />
                        </wpfui:CardControl>

                        <wpfui:CardControl Margin="0,0,0,8" Icon="LockClosed24">
                            <wpfui:CardControl.Header>
                                <TextBlock Text="{x:Static resources:Resource.OsdSettings_General_LockPosition}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                            </wpfui:CardControl.Header>
                             <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <wpfui:Button
                                    Padding="8,4"
                                    Margin="0,0,12,0"
                                    VerticalAlignment="Center"
                                    Click="ResetPositionButton_Click"
                                    ToolTip="{x:Static resources:Resource.OsdSettings_General_ResetPosition}"
                                    Icon="ArrowReset24" />
                                <wpfui:ToggleSwitch x:Name="_osdLockPosition" VerticalAlignment="Center" Checked="OsdLockPosition_CheckedOrUnchecked" Unchecked="OsdLockPosition_CheckedOrUnchecked" />
                            </StackPanel>
                        </wpfui:CardControl>
                    </StackPanel>
                </TabItem>

                <TabItem Header="{x:Static resources:Resource.OsdSettings_Tabs_Appearance}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="0,0,12,0">
                            <wpfui:CardControl Margin="0,0,0,8" Icon="Layer24">
                                <wpfui:CardControl.Header>
                                    <StackPanel>
                                        <TextBlock Text="{x:Static resources:Resource.OsdSettings_Appearance_Opacity}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                        <TextBlock x:Name="_opacityValueText" FontSize="11" Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                                    </StackPanel>
                                </wpfui:CardControl.Header>
                                <Slider
                                    x:Name="_osdOpacitySlider"
                                    Width="140"
                                    Maximum="1"
                                    Minimum="0"
                                    SmallChange="0.1"
                                    TickFrequency="0.1"
                                    ValueChanged="OsdOpacitySlider_ValueChanged" />
                            </wpfui:CardControl>

                            <wpfui:CardControl Margin="0,0,0,8" Icon="AppGeneric24">
                                <wpfui:CardControl.Header>
                                    <StackPanel>
                                        <TextBlock Text="{x:Static resources:Resource.OsdSettings_Appearance_CornerRadius}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                        <TextBlock x:Name="_cornerRadiusValueText" FontSize="11" Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                                    </StackPanel>
                                </wpfui:CardControl.Header>
                                <StackPanel Orientation="Vertical">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                        <TextBlock Text="{x:Static resources:Resource.OsdSettings_Appearance_CornerRadiusTop}" Margin="0,0,8,0" VerticalAlignment="Center" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                        <Slider
                                            x:Name="_osdCornerRadiusTopSlider"
                                            Width="140"
                                            Maximum="50"
                                            Minimum="0"
                                            SmallChange="1"
                                            TickFrequency="1"
                                            IsSnapToTickEnabled="True"
                                            ValueChanged="OsdCornerRadiusTopSlider_ValueChanged" />
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                                        <TextBlock Text="{x:Static resources:Resource.OsdSettings_Appearance_CornerRadiusBottom}" Margin="0,0,8,0" VerticalAlignment="Center" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                        <Slider
                                            x:Name="_osdCornerRadiusBottomSlider"
                                            Width="140"
                                            Maximum="50"
                                            Minimum="0"
                                            SmallChange="1"
                                            TickFrequency="1"
                                            IsSnapToTickEnabled="True"
                                            ValueChanged="OsdCornerRadiusBottomSlider_ValueChanged" />
                                    </StackPanel>
                                </StackPanel>
                            </wpfui:CardControl>

                            <wpfui:CardControl Margin="0,0,0,8" Icon="TextFontSize24">
                                <wpfui:CardControl.Header>
                                    <TextBlock Text="{x:Static resources:Resource.OsdSettings_Appearance_FontSize}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                </wpfui:CardControl.Header>
                                <wpfui:NumberBox
                                    x:Name="_osdFontSize"
                                    Width="100"
                                    Maximum="24"
                                    Minimum="8"
                                    SpinButtonPlacementMode="Compact"
                                    ValueChanged="OsdFontSize_ValueChanged" />
                            </wpfui:CardControl>

                            <wpfui:CardControl Margin="0,0,0,8" Icon="Color24">
                                <wpfui:CardControl.Header>
                                    <TextBlock Text="{x:Static resources:Resource.OsdSettings_Appearance_BackgroundColor}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                </wpfui:CardControl.Header>
                                <controls:ColorPickerControl
                                    x:Name="_osdBackgroundColorPicker"
                                    HorizontalAlignment="Right"
                                    ColorChangedDelayed="OsdBackgroundColorPicker_ColorChangedDelayed" />
                            </wpfui:CardControl>

                            <wpfui:CardControl Margin="0,0,0,8" Icon="Grid24">
                                <wpfui:CardControl.Header>
                                    <TextBlock Text="{x:Static resources:Resource.OsdSettings_Appearance_CategoryColor}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                </wpfui:CardControl.Header>
                                <controls:ColorPickerControl
                                    x:Name="_categoryColorPicker"
                                    HorizontalAlignment="Right"
                                    ColorChangedDelayed="ColorPicker_ColorChangedDelayed" />
                            </wpfui:CardControl>

                            <wpfui:CardControl Margin="0,0,0,8" Icon="Tag24">
                                <wpfui:CardControl.Header>
                                    <TextBlock Text="{x:Static resources:Resource.OsdSettings_Appearance_LabelColor}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                </wpfui:CardControl.Header>
                                <controls:ColorPickerControl
                                    x:Name="_labelColorPicker"
                                    HorizontalAlignment="Right"
                                    ColorChangedDelayed="ColorPicker_ColorChangedDelayed" />
                            </wpfui:CardControl>

                            <wpfui:CardControl Margin="0,0,0,8" Icon="TextNumberFormat24">
                                <wpfui:CardControl.Header>
                                    <TextBlock Text="{x:Static resources:Resource.OsdSettings_Appearance_ValueColor}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                </wpfui:CardControl.Header>
                                <controls:ColorPickerControl
                                    x:Name="_valueColorPicker"
                                    HorizontalAlignment="Right"
                                    ColorChangedDelayed="ColorPicker_ColorChangedDelayed" />
                            </wpfui:CardControl>

                            <wpfui:CardControl Margin="0,0,0,8" Icon="Warning24">
                                <wpfui:CardControl.Header>
                                    <TextBlock Text="{x:Static resources:Resource.OsdSettings_Appearance_WarningColor}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                </wpfui:CardControl.Header>
                                <controls:ColorPickerControl
                                    x:Name="_warningColorPicker"
                                    HorizontalAlignment="Right"
                                    ColorChangedDelayed="ColorPicker_ColorChangedDelayed" />
                            </wpfui:CardControl>

                            <wpfui:CardControl Margin="0,0,0,8" Icon="ErrorCircle24">
                                <wpfui:CardControl.Header>
                                    <TextBlock Text="{x:Static resources:Resource.OsdSettings_Appearance_CriticalColor}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                </wpfui:CardControl.Header>
                                <controls:ColorPickerControl
                                    x:Name="_criticalColorPicker"
                                    HorizontalAlignment="Right"
                                    ColorChangedDelayed="ColorPicker_ColorChangedDelayed" />
                            </wpfui:CardControl>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="{x:Static resources:Resource.OsdSettings_Tabs_Thresholds}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="0,0,12,0">
                            <GroupBox Header="{x:Static resources:Resource.OsdSettings_Thresholds_Performance}">
                                <StackPanel>
                                    <wpfui:CardControl
                                        Margin="0,0,0,8"
                                        ToolTip="{x:Static resources:Resource.OsdSettings_Thresholds_FpsRedline_Description}"
                                        Icon="FastForward24">
                                        <wpfui:CardControl.Header>
                                            <TextBlock Text="{x:Static resources:Resource.OsdSettings_Thresholds_FpsRedline}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                        </wpfui:CardControl.Header>
                                        <wpfui:NumberBox
                                            x:Name="_fpsCritical"
                                            Width="100"
                                            Maximum="1000"
                                            Minimum="0"
                                            SpinButtonPlacementMode="Compact"
                                            ValueChanged="Threshold_ValueChanged" />
                                    </wpfui:CardControl>
                                    <wpfui:CardControl
                                        Margin="0"
                                        ToolTip="{x:Static resources:Resource.OsdSettings_Thresholds_LowFpsDelta_Description}"
                                        Icon="LineStyle24">
                                        <wpfui:CardControl.Header>
                                            <TextBlock Text="{x:Static resources:Resource.OsdSettings_Thresholds_LowFpsDelta}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                        </wpfui:CardControl.Header>
                                        <wpfui:NumberBox
                                            x:Name="_lowFpsDelta"
                                            Width="100"
                                            Maximum="1000"
                                            Minimum="0"
                                            SpinButtonPlacementMode="Compact"
                                            ValueChanged="Threshold_ValueChanged" />
                                    </wpfui:CardControl>
                                </StackPanel>
                            </GroupBox>

                            <GroupBox Header="{x:Static resources:Resource.OsdSettings_Thresholds_Temperature}">
                                <StackPanel>
                                    <wpfui:CardControl Margin="0,0,0,8" Icon="Temperature24">
                                        <wpfui:CardControl.Header>
                                            <TextBlock Text="{x:Static resources:Resource.OsdSettings_Thresholds_Warning}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                        </wpfui:CardControl.Header>
                                        <wpfui:NumberBox
                                            x:Name="_tempWarning"
                                            Width="100"
                                            Maximum="110"
                                            Minimum="0"
                                            SpinButtonPlacementMode="Compact"
                                            ValueChanged="Threshold_ValueChanged" />
                                    </wpfui:CardControl>
                                    <wpfui:CardControl Margin="0" Icon="Temperature24">
                                        <wpfui:CardControl.Header>
                                            <TextBlock Text="{x:Static resources:Resource.OsdSettings_Thresholds_Critical}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                        </wpfui:CardControl.Header>
                                        <wpfui:NumberBox
                                            x:Name="_tempCritical"
                                            Width="100"
                                            Maximum="110"
                                            Minimum="0"
                                            SpinButtonPlacementMode="Compact"
                                            ValueChanged="Threshold_ValueChanged" />
                                    </wpfui:CardControl>
                                </StackPanel>
                            </GroupBox>

                            <GroupBox Header="{x:Static resources:Resource.OsdSettings_Thresholds_Usage}">
                                <StackPanel>
                                    <wpfui:CardControl Margin="0,0,0,8" Icon="DataUsage24">
                                        <wpfui:CardControl.Header>
                                            <TextBlock Text="{x:Static resources:Resource.OsdSettings_Thresholds_Warning}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                        </wpfui:CardControl.Header>
                                        <wpfui:NumberBox
                                            x:Name="_usageWarning"
                                            Width="100"
                                            Maximum="100"
                                            Minimum="0"
                                            SpinButtonPlacementMode="Compact"
                                            ValueChanged="Threshold_ValueChanged" />
                                    </wpfui:CardControl>
                                    <wpfui:CardControl Margin="0" Icon="DataUsage24">
                                        <wpfui:CardControl.Header>
                                            <TextBlock Text="{x:Static resources:Resource.OsdSettings_Thresholds_Critical}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                        </wpfui:CardControl.Header>
                                        <wpfui:NumberBox
                                            x:Name="_usageCritical"
                                            Width="100"
                                            Maximum="100"
                                            Minimum="0"
                                            SpinButtonPlacementMode="Compact"
                                            ValueChanged="Threshold_ValueChanged" />
                                    </wpfui:CardControl>
                                </StackPanel>
                            </GroupBox>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="{x:Static resources:Resource.OsdSettings_Tabs_SensorItems}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="_itemsStackPanel" Margin="0,0,12,0" />
                    </ScrollViewer>
                </TabItem>
            </TabControl>

            <wpfui:Button
                Grid.Row="1"
                Margin="0,16,0,0"
                HorizontalAlignment="Stretch"
                Click="CloseButton_Click"
                Appearance="Primary"
                Content="{Binding Source={x:Static resources:Resource.Close}}" />
        </Grid>
    </Grid>
</local:BaseWindow>