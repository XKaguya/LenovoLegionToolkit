<local:BaseWindow
    x:Class="LenovoLegionToolkit.WPF.Windows.Settings.SpecialKeyDetailWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:LenovoLegionToolkit.WPF.Controls"
    xmlns:custom="clr-namespace:LenovoLegionToolkit.WPF.Controls.Custom"
    xmlns:local="clr-namespace:LenovoLegionToolkit.WPF.Windows"
    xmlns:resources="clr-namespace:LenovoLegionToolkit.WPF.Resources"
    xmlns:utils="clr-namespace:LenovoLegionToolkit.WPF.Utils"
    xmlns:wpfui="http://schemas.lepo.co/wpfui/2022/xaml"
    Width="480"
    Height="600"
    MinWidth="400"
    MinHeight="500"
    FlowDirection="{x:Static utils:LocalizationHelper.Direction}"
    ResizeMode="CanMinimize"
    ShowInTaskbar="False"
    WindowStartupLocation="CenterOwner">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <wpfui:TitleBar
            Grid.Row="0"
            CanMaximize="false"
            ShowMaximize="false"
            ShowMinimize="false"
            UseSnapLayout="false" />

        <Grid
            Grid.Row="0"
            Height="24"
            Margin="12,8,12,8">
            <TextBlock
                x:Name="_title"
                VerticalAlignment="Center"
                FontSize="12"
                IsHitTestVisible="False" />
        </Grid>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="12,0,16,0">
                <custom:CardControl Margin="0,0,0,12">
                    <custom:CardControl.Header>
                        <controls:CardHeaderControl Title="Mode" Subtitle="{x:Static resources:Resource.SpecialKey_Mode_Custom_Description}" />
                    </custom:CardControl.Header>
                    <ComboBox
                        x:Name="_modeComboBox"
                        MinWidth="150"
                        SelectionChanged="ModeComboBox_SelectionChanged" />
                </custom:CardControl>

                <StackPanel x:Name="_customPanel" Visibility="Collapsed">

                    <custom:CardControl Margin="0,0,0,12">
                        <custom:CardControl.Header>
                            <controls:CardHeaderControl Title="{x:Static resources:Resource.SelectSpecialKeyPipelinesWindow_ShowThisApp}" />
                        </custom:CardControl.Header>
                        <wpfui:ToggleSwitch x:Name="_showThisAppToggle" Click="ShowThisAppToggle_Click" />
                    </custom:CardControl>

                    <TextBlock
                        Margin="0,0,0,8"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                        Text="{x:Static resources:Resource.SelectSpecialKeyPipelinesWindow_List_Description}"
                        TextWrapping="Wrap" />

                    <controls:LoadableControl
                        x:Name="_loader"
                        Margin="0,0,0,8"
                        IndicatorVerticalAlignment="Center">

                        <Border CornerRadius="8">
                            <Border.Background>
                                <SolidColorBrush Color="{DynamicResource ControlFillColorDefault}" />
                            </Border.Background>

                            <wpfui:DynamicScrollViewer MaxHeight="200">
                                <ItemsControl
                                    x:Name="_list"
                                    Margin="8,8,16,0"
                                    HorizontalContentAlignment="Stretch" />
                            </wpfui:DynamicScrollViewer>
                        </Border>

                    </controls:LoadableControl>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>

        <Grid Grid.Row="2" Margin="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <wpfui:Button
                Grid.Column="1"
                MinWidth="100"
                Appearance="Primary"
                Click="SaveButton_Click"
                Content="{x:Static resources:Resource.Save}" />

            <wpfui:Button
                Grid.Column="2"
                MinWidth="100"
                Margin="8,0,0,0"
                Click="CancelButton_Click"
                Content="{x:Static resources:Resource.Cancel}" />
        </Grid>
    </Grid>
</local:BaseWindow>
