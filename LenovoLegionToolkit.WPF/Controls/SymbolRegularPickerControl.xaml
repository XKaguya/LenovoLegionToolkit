<UserControl
    x:Class="LenovoLegionToolkit.WPF.Controls.SymbolRegularPickerControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:resources="clr-namespace:LenovoLegionToolkit.WPF.Resources"
    xmlns:wpfui="http://schemas.lepo.co/wpfui/2022/xaml">

    <Grid>
        <wpfui:Button
            x:Name="_button"
            Width="38"
            Height="38"
            Padding="0"
            Click="Button_Click">
            <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                <wpfui:SymbolIcon x:Name="_symbolIcon" FontSize="20" Symbol="Empty" />
                <wpfui:SymbolIcon x:Name="_overlayIcon" FontSize="20" Symbol="Empty" Visibility="Collapsed" />
            </Grid>
        </wpfui:Button>

        <Popup
            x:Name="_popup"
            Width="320"
            AllowsTransparency="True"
            HorizontalOffset="-141"
            Placement="Bottom"
            StaysOpen="False"
            VerticalOffset="4">
            <Border
                Background="{DynamicResource ApplicationBackgroundBrush}"
                BorderBrush="{DynamicResource KeyboardFocusBorderColorBrush}"
                BorderThickness="0.5"
                ClipToBounds="True"
                CornerRadius="8">
                <StackPanel>
                    <wpfui:TextBox
                        x:Name="_filterTextBox"
                        Margin="8,8,8,4"
                        Icon="Search24"
                        PlaceholderEnabled="True"
                        PlaceholderText="{x:Static resources:Resource.Filter}"
                        TextChanged="FilterTextBox_TextChanged" />

                    <ScrollViewer
                        x:Name="_scrollViewer"
                        Height="220"
                        Margin="4,0,4,0"
                        ScrollChanged="ScrollViewer_ScrollChanged"
                        HorizontalScrollBarVisibility="Disabled"
                        VerticalScrollBarVisibility="Auto">
                        <WrapPanel x:Name="_iconsPanel" Margin="4" />
                    </ScrollViewer>

                    <wpfui:Button
                        MinWidth="80"
                        Margin="0,4,0,8"
                        HorizontalAlignment="Center"
                        Click="DefaultButton_Click"
                        Content="{x:Static resources:Resource.Default}" />
                </StackPanel>
            </Border>
        </Popup>
    </Grid>

</UserControl>
